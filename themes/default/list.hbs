{{> breadcrumb}}
<h1>{{type.label}}</h1>

<div class="card-list">
  {{#each items}}
  <article class="card">
    {{!-- 画像が無ければサイト情報の既定OGP画像をサムネイルにフォールバック --}}
    {{#if (thumbnail this @root.site)}}<img src="{{thumbnail this @root.site}}" alt="{{this.title}}">{{/if}}
    <div class="card-body">
      <h3><a href="{{this.url}}">{{this.title}}</a></h3>
      {{#if this.publishedAt}}<time>{{formatDate this.publishedAt "YYYY年MM月DD日"}}</time>{{/if}}
      <p>{{truncate this.body 120}}</p>
    </div>
  </article>
  {{/each}}
</div>

{{> pagination}}
